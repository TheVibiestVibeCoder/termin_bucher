# Admin
# Use ADMIN_PASSWORD_HASH in production (recommended).
# Generate one with:
#   php -r "echo password_hash('replace-with-strong-password', PASSWORD_DEFAULT), PHP_EOL;"
# Keep ADMIN_PASSWORD empty when using ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# Email (used for all outgoing emails)
MAIL_FROM=workshops@disinfoconsulting.eu
MAIL_FROM_NAME=Disinfo Consulting Workshops

# Site
# Must be an absolute HTTPS URL for links in outgoing emails.
SITE_URL=https://disinfoconsulting.eu/workshops
SITE_NAME=Disinfo Consulting - Workshops

# Database (path is relative to project root)
# Production recommendation: place the database outside the public web root.
# Example: DB_PATH=../private-data/bookings.db
DB_PATH=data/bookings.db
